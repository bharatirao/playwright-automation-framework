pipeline {
    agent any

    tools {
        nodejs "NodeJS"
    }

    parameters {
        choice(
            name: 'BRANCH',
            choices: ['main', 'master'],
            description: 'Select the branch to build'
        )
        choice(
            name: 'BROWSER',
            choices: ['chromium', 'firefox', 'webkit', 'Google Chrome', 'ALL'],
            description: 'Select browser to run tests or ALL'
        )
    }

    environment {
        REPORT_URL = "${env.BUILD_URL}playwright-report/index.html"
    }

    stages {

        stage('Clean') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                echo "Checking out branch: ${params.BRANCH}"
                git branch: "${params.BRANCH}", url: 'https://github.com/bharatirao/playwright-automation-framework.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'node -v'
                bat 'npm -v'
                bat 'npm install'
                bat 'npx playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    if (params.BROWSER == 'ALL') {
                        echo "Running tests on ALL browsers in parallel"
                        parallel(
    Chromium: { bat 'npx playwright test --project=chromium --reporter=json --output=results/chromium' },
    Firefox: { bat 'npx playwright test --project=firefox --reporter=json --output=results/firefox' },
    Webkit: { bat 'npx playwright test --project=webkit --reporter=json --output=results/webkit' },
    Chrome: { bat 'npx playwright test --project="Google Chrome" --reporter=json --output=results/chrome' }
)
                    } else {
                        echo "Running tests on browser: ${params.BROWSER}"
                        bat "npx playwright test --project=${params.BROWSER} --reporter=json --output=results/${params.BROWSER}"
                    }
                }
            }
        }

        stage('Publish Report') {
            steps {
                publishHTML([
                    reportDir: 'playwright-report',
                    reportFiles: 'index.html',
                    reportName: 'Playwright HTML Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
        }

       success {
    slackSend(
        channel: 'playwright-automation-results',
        message: """✅ *Build SUCCESS*
Job: ${env.JOB_NAME} #${env.BUILD_NUMBER}
Branch: ${params.BRANCH}
Browser: ${params.BROWSER}

Report: ${env.REPORT_URL}
""",
        tokenCredentialId: 'slack-bot-token',
        botUser: true
    )
}

     failure {
    slackSend(
        channel: 'playwright-automation-results',
        message: """❌ *Build FAILED*
Job: ${env.JOB_NAME} #${env.BUILD_NUMBER}
Branch: ${params.BRANCH}
Browser: ${params.BROWSER}

Report: ${env.REPORT_URL}
""",
        tokenCredentialId: 'slack-bot-token',
        botUser: true
    )
}
    }
}

