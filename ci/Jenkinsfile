pipeline {
    agent any

    tools {
        nodejs "NodeJS"
    }

    parameters {
        choice(
            name: 'BRANCH',
            choices: ['main', 'master'],
            description: 'Select the branch to build'
        )
        choice(
            name: 'BROWSER',
            choices: ['chromium', 'firefox', 'webkit', 'Google Chrome', 'ALL'],
            description: 'Select browser to run tests or ALL'
        )
    }

    environment {
        REPORT_URL = "${BUILD_URL}playwright-report/index.html"
    }

    stages {

        stage('Clean') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                echo "Checking out branch: ${params.BRANCH}"
                git branch: "${params.BRANCH}", url: 'https://github.com/bharatirao/playwright-automation-framework.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'node -v'
                bat 'npm -v'
                bat 'npm install'
                bat 'npx playwright install'
            }
        }

        stage('Run Tests') {
            steps {
                script {
                    if (params.BROWSER == 'ALL') {
                        echo "Running tests on ALL browsers in parallel"

                        parallel(
                            failFast: false,

                            Chromium: {
                                bat 'npx playwright test --project=chromium --reporter=json=results/chromium/test-results.json,html --output=results/chromium || exit 0'
                            },

                            Firefox: {
                                bat 'npx playwright test --project=firefox --reporter=json=results/firefox/test-results.json,html --output=results/firefox || exit 0'
                            },

                            Webkit: {
                                bat 'npx playwright test --project=webkit --reporter=json=results/webkit/test-results.json,html --output=results/webkit || exit 0'
                            },

                            Chrome: {
                                bat 'npx playwright test --project="Google Chrome" --reporter=json=results/chrome/test-results.json,html --output=results/chrome || exit 0'
                            }
                        )

                    } else {
                        echo "Running tests on browser: ${params.BROWSER}"

                        def folder = params.BROWSER == 'Google Chrome' ? 'chrome' : params.BROWSER

                        bat "npx playwright test --project=\"${params.BROWSER}\" --reporter=json=results/${folder}/test-results.json,html --output=results/${folder} || exit 0"
                    }
                }
            }
        }

        stage('Publish Report') {
            steps {
                publishHTML([
                    reportDir: 'playwright-report',
                    reportFiles: 'index.html',
                    reportName: 'Playwright HTML Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])
            }
        }
    }

    post {

        always {
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
        }

        success {
            script {
                def summary = getBrowserWiseSummary()

                slackSend(
                    channel: 'playwright-automation-results',
                    color: 'good',
                    message: """✅ *Build SUCCESS*
Job: ${env.JOB_NAME} #${env.BUILD_NUMBER}
Branch: ${params.BRANCH}
Browser: ${params.BROWSER}

${summary}

Report: ${env.REPORT_URL}
""",
                    tokenCredentialId: 'slack-bot-token',
                    botUser: true
                )
            }
        }

        unstable {
            script {
                def summary = getBrowserWiseSummary()

                slackSend(
                    channel: 'playwright-automation-results',
                    color: 'warning',
                    message: """⚠️ *Build UNSTABLE*
Job: ${env.JOB_NAME} #${env.BUILD_NUMBER}
Branch: ${params.BRANCH}
Browser: ${params.BROWSER}

${summary}

Report: ${env.REPORT_URL}
""",
                    tokenCredentialId: 'slack-bot-token',
                    botUser: true
                )
            }
        }

        failure {
            script {
                def summary = getBrowserWiseSummary()

                slackSend(
                    channel: 'playwright-automation-results',
                    color: 'danger',
                    message: """❌ *Build FAILED*
Job: ${env.JOB_NAME} #${env.BUILD_NUMBER}
Branch: ${params.BRANCH}
Browser: ${params.BROWSER}

${summary}

Report: ${env.REPORT_URL}
""",
                    tokenCredentialId: 'slack-bot-token',
                    botUser: true
                )
            }
        }
    }
}

def getBrowserWiseSummary() {

    def browsers = [
        "chromium": "Chromium",
        "firefox": "Firefox",
        "webkit": "Webkit",
        "chrome": "Chrome"
    ]

    def finalSummary = "📊 *Test Summary (Per Browser)*\n\n"

    browsers.each { key, name ->

        def filePath = "results/${key}/test-results.json"

        if (!fileExists(filePath)) {
            finalSummary += "${name} → ⚠️ No data\n"
            return
        }

        def json = readJSON file: filePath

        int passed = 0
        int failed = 0
        int skipped = 0

        json.suites.each { suite ->
            suite.specs.each { spec ->
                spec.tests.each { test ->
                    test.results.each { result ->
                        if (result.status == "passed") passed++
                        else if (result.status == "failed") failed++
                        else if (result.status == "skipped") skipped++
                    }
                }
            }
        }

        finalSummary += "${name} → ✅ ${passed} | ❌ ${failed} | ⏭ ${skipped}\n"
    }

    return finalSummary
}