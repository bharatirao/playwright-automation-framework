pipeline {
    agent any

    tools {
        nodejs "NodeJS"
    }

    stages {

        stage('Clean') {
        steps {
            deleteDir()
        }
    }

        stage('Checkout') {
            steps {
                git 'https://github.com/bharatirao/playwright-automation-framework.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'node -v'
                bat 'npm -v'
                bat 'npm install'
                bat 'npx playwright install'
            }
        }

        stage('Run Tests in Parallel') {
            parallel {

                stage('Chromium') {
                    steps {
                        bat 'npx playwright test --project=chromium --output=results/chromium'
                    }
                }

                stage('Firefox') {
                    steps {
                        bat 'npx playwright test --project=firefox --output=results/firefox'
                    }
                }

                stage('Webkit') {
                    steps {
                        bat 'npx playwright test --project=webkit --output=results/webkit'
                    }
                }

                stage('Chrome (Channel)') {
                    steps {
                       bat 'npx playwright test --project="Google Chrome" --output=results/chrome'
                    }
                }
            }
        }

        stage('Publish Report') {
            steps {
                publishHTML([
                    reportDir: 'playwright-report',
                    reportFiles: 'index.html',
                    reportName: 'Playwright HTML Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
        }
        success {
            echo 'Tests Passed ✅'
        }
        failure {
            echo 'Tests Failed ❌'
        }
    }
}