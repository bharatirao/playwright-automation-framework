pipeline {
    agent any

    tools {
        nodejs "NodeJS"
    }

    environment {
        REPORT_URL = "${env.BUILD_URL}playwright-report/index.html"
    }

    stages {

        stage('Clean') {
            steps {
                deleteDir()
            }
        }

        stage('Checkout') {
            steps {
                git 'https://github.com/bharatirao/playwright-automation-framework.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'node -v'
                bat 'npm -v'
                bat 'npm install'
                bat 'npx playwright install'
            }
        }

        stage('Run Tests in Parallel') {
            parallel {

                stage('Chromium') {
                    steps {
                        bat 'npx playwright test --project=chromium --output=results/chromium || exit 0'
                    }
                }

                stage('Firefox') {
                    steps {
                        bat 'npx playwright test --project=firefox --output=results/firefox || exit 0'
                    }
                }

                stage('Webkit') {
                    steps {
                        bat 'npx playwright test --project=webkit --output=results/webkit || exit 0'
                    }
                }

                stage('Chrome (Channel)') {
                    steps {
                        bat 'npx playwright test --project="Google Chrome" --output=results/chrome || exit 0'
                    }
                }
            }
        }

        stage('Publish Report') {
            steps {
                publishHTML([
                    reportDir: 'playwright-report',
                    reportFiles: 'index.html',
                    reportName: 'Playwright HTML Report',
                    keepAll: true,
                    alwaysLinkToLastBuild: true,
                    allowMissing: false
                ])
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'playwright-report/**', allowEmptyArchive: true
        }

        success {
            script {
                def summary = getPlaywrightSummary()
                slackSend(
                    channel: '#playwright-automation-results',
                    message: "✅ Build SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}\n${summary}\nHTML Report: ${env.REPORT_URL}",
                    webhookUrl: credentials('slack-webhook')
                )
            }
        }

        failure {
            script {
                def summary = getPlaywrightSummary()
                slackSend(
                    channel: '#playwright-automation-results',
                    message: "❌ Build FAILED: ${env.JOB_NAME} #${env.BUILD_NUMBER}\n${summary}\nHTML Report: ${env.REPORT_URL}",
                    webhookUrl: credentials('slack-webhook')
                )
            }
        }
    }
}

// Utility to summarize test results per browser
def getPlaywrightSummary() {
    def summary = ""
    def browsers = ["chromium", "firefox", "webkit", "chrome"]
    browsers.each { browser ->
        def resultFile = "results/${browser}/result.txt"
        if (fileExists(resultFile)) {
            def result = readFile(resultFile).trim()
            summary += "${browser.capitalize()}: ${result}\n"
        } else {
            summary += "${browser.capitalize()}: No results\n"
        }
    }
    return summary
}